# ═══════════════════════════════════════════════════════════════════
# MeterFlow API — Production Environment Variables
# Copy this to your hosting provider's environment variable settings.
# NEVER commit a file with real secrets to version control.
# ═══════════════════════════════════════════════════════════════════

# ── Server ──────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── MongoDB Atlas ────────────────────────────────────────────────────
# Get from: https://cloud.mongodb.com → Connect → Drivers
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/meterflow?retryWrites=true&w=majority

# ── Upstash Redis ────────────────────────────────────────────────────
# Get from: https://console.upstash.com → Redis → Connect → ioredis
# Must use rediss:// (TLS) for Upstash
REDIS_URL=rediss://default:<password>@<host>.upstash.io:<port>

# ── JWT Secrets ──────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# IMPORTANT: Use DIFFERENT secrets for access and refresh tokens
JWT_ACCESS_SECRET=<64-char-hex-string>
JWT_REFRESH_SECRET=<different-64-char-hex-string>
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── AES Encryption (for upstream API credentials) ────────────────────
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=<64-char-hex-string>

# ── Email (Resend recommended for production) ────────────────────────
# https://resend.com → API Keys
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=re_<your-resend-api-key>
EMAIL_FROM=noreply@yourdomain.com

# ── App URLs ─────────────────────────────────────────────────────────
APP_URL=https://app.yourdomain.com
API_URL=https://api.yourdomain.com

# ── Stripe (for real payment processing) ─────────────────────────────
# https://dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_live_<your-stripe-secret>
STRIPE_WEBHOOK_SECRET=whsec_<your-stripe-webhook-secret>

# ── Seed Script (optional — used by npm run seed) ───────────────────
SEED_ADMIN_EMAIL=admin@yourdomain.com
SEED_ADMIN_PASSWORD=<strong-password-min-16-chars>
SEED_DEMO_EMAIL=demo@yourdomain.com
SEED_DEMO_PASSWORD=<strong-password-min-16-chars>

# ═══════════════════════════════════════════════════════════════════
# Render.com setup:
#   1. Create a new Web Service → connect your GitHub repo
#   2. Build command: npm install && npm run build
#   3. Start command: npm start
#   4. Add all variables above in the Environment tab
#   5. After first deploy: run seed via Render Shell → npm run seed
#
# Railway.app setup:
#   1. New Project → Deploy from GitHub repo
#   2. Set all variables in Variables tab
#   3. Railway auto-detects Node.js and runs npm start
# ═══════════════════════════════════════════════════════════════════
