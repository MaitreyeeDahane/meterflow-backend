# ── Server ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── MongoDB ─────────────────────────────────────────────────────────
# Local: mongodb://localhost:27017/meterflow
# Atlas: mongodb+srv://<user>:<pass>@cluster.mongodb.net/meterflow
MONGO_URI=mongodb://localhost:27017/meterflow

# ── Redis ───────────────────────────────────────────────────────────
# Local: redis://localhost:6379
# Upstash: rediss://<user>:<pass>@<host>:<port>
REDIS_URL=redis://localhost:6379

# ── JWT (generate with: openssl rand -hex 32) ───────────────────────
JWT_ACCESS_SECRET=replace_with_64_char_hex_secret_here_minimum_32_chars
JWT_REFRESH_SECRET=replace_with_different_64_char_hex_secret_here_minimum
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Email ────────────────────────────────────────────────────────────
# Dev: use Ethereal (auto-generated) or Mailtrap
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@meterflow.dev

# ── Encryption (AES-256) ────────────────────────────────────────────
# generate with: openssl rand -hex 32
ENCRYPTION_KEY=replace_with_64_char_hex_key_here_minimum_32_chars_required

# ── App URLs ────────────────────────────────────────────────────────
APP_URL=http://localhost:5173
API_URL=http://localhost:3000

# ── Stripe (optional for payments) ─────────────────────────────────
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
